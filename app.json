{
  "expo": {
    "name": "ClerraAlarm",
    "slug": "ClerraAlarm",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/ClerraAlarm Light1.png",
      "resizeMode": "contain",
      "backgroundColor": "#FEF4EC",
      "dark": {
        "image": "./assets/ClerraAlarm Light1.png",
        "backgroundColor": "#121212"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.clerra.alarm",
      "infoPlist": {
        "NSCameraUsageDescription": "Camera is needed for photo, jump, push-up, and barcode challenges",
        "NSMicrophoneUsageDescription": "Microphone is needed to record voice commitments",
        "NSMotionUsageDescription": "Motion sensors are needed for jump, walk, and push-up challenges",
        "UIBackgroundModes": [
          "audio",
          "fetch",
          "audio",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      },
      "appleTeamId": "9GPD8X5J7J"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FEF4EC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.clerra.alarm",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.VIBRATE",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.USE_EXACT_ALARM",
        "android.permission.ACTIVITY_RECOGNITION",
        "android.permission.HIGH_SAMPLING_RATE_SENSORS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.USE_FULL_SCREEN_INTENT"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#e94560",
          "sounds": [
            "./assets/sounds/alarm_clock.wav",
            "./assets/sounds/air_raid.wav",
            "./assets/sounds/beep.wav",
            "./assets/sounds/freesound_community_alert_33762.wav",
            "./assets/sounds/freesound_community_siren_alert_96052.wav",
            "./assets/sounds/freesound_community_wind_up_clock_alarm_bell_64219.wav",
            "./assets/sounds/jeremayjimenez_taiwan_eas_alarm_501825.wav",
            "./assets/sounds/reminder_aggressive.wav",
            "./assets/sounds/reminder_classic.wav",
            "./assets/sounds/reminder_peaceful.wav",
            "./assets/sounds/reminder_viral.wav",
            "./assets/sounds/soundreality_christmas_ringing_bells_ringtone_456343.wav",
            "./assets/sounds/u_xg7ssi08yr_old_telephone_ringing_362034.wav"
          ]
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Clerra Alarm to access your camera for photo, jump, push-up, and barcode challenges"
        }
      ],
      "expo-sensors",
      "@react-native-community/datetimepicker",
      "expo-font",
      "expo-video",
      "expo-asset",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "extra": {
      "eas": {
        "projectId": "fd0aa849-5c17-4d53-966b-db4f2e71ae77"
      }
    }
  }
}
